      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Italic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" as="image" href="/images/cover.webp" />
    <link rel="preload" as="image" href="/images/SV26_FB.svg" />
    <link rel="preload" as="image" href="/images/SV26_IG.svg" />
    <link rel="preload" as="image" href="/images/SV26_YT.svg" />
    <link rel="preload" as="image" href="/images/arrow-up-circle.svg" />
    <link rel="preload" as="image" href="/images/logo_b_transparent.webp" />
    <link rel="preload" as="image" href="/images/tym/amalka.webp" />
    <link rel="preload" as="image" href="/images/tym/matej.webp" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        position: relative;
        z-index: 10;
        width: 100%;
        padding-top: 70px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 1200px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        color: #424753;
        text-align: center;
        width: 100%;
        z-index: 999;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
      }

      .about p {
        margin-bottom: 1.5rem;
        line-height: 2;
      }

      .about p.spacing {
        letter-spacing: 1.4px;
      }

      .tabs {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin: 2rem 0;
        flex-wrap: wrap;
      }

      .tab-button {
        background-color: #fff;
        border: 2px solid #eeaf13;
        color: #eeaf13;
        padding: 0.75rem 2rem;
        cursor: pointer;
        font-size: 16px;
        letter-spacing: 1.2px;
        transition: all 0.3s ease;
        text-transform: uppercase;
      }

      .tab-button:hover {
        background-color: #eeaf13;
        color: #fff;
      }

      .tab-button.active {
        background-color: #eeaf13;
        color: #fff;
      }

      .tab-content {
        display: none;
        max-width: 900px;
        margin: 0 auto;
        padding: 0 15px;
      }

      .tab-content.active {
        display: block;
      }

      .schedule-table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
      }

      .schedule-table th,
      .schedule-table td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid #ddd;
      }

      .schedule-table th {
        background-color: #1a2764;
        color: #fff;
        font-weight: normal;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        font-size: 14px;
      }

      .schedule-table td {
        color: #424753;
        line-height: 1.8;
      }

      .schedule-table td:first-child {
        font-weight: bold;
        white-space: nowrap;
        width: 180px;
      }

      .schedule-table tr:hover {
        background-color: #f5f5f5;
      }

      /* Mobile / tablet 640px a méně */
      @media (max-width: 640px) {
        .about-text {
          width: auto;
        }

        .about-flex {
          flex-direction: column;
          gap: 1rem;
        }

        .tabs {
          flex-direction: column;
          gap: 0.5rem;
        }

        .tab-button {
          width: 100%;
          padding: 0.75rem 1rem;
        }

        .schedule-table {
          font-size: 14px;
        }

        .schedule-table th,
        .schedule-table td {
          padding: 0.75rem 0.5rem;
        }

        .schedule-table td:first-child {
          width: auto;
          white-space: normal;
        }
      }
    </style>
  </head>

  <body>
