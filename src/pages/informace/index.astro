---
import Navigation from "../../components/Navigation.astro";
import MobileMenu from "../../components/MobileMenu.astro";
import Footer from "../../components/Footer.astro";
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Informace - Studentský Velehrad 2026</title>
    <meta
      name="description"
      content="Informace o parkování na Studentském Velehradě 2026 v obci Velehrad."
    />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://studentskyvelehrad.cz/informace"
    />
    <meta property="og:title" content="Informace - Studentský Velehrad 2026" />
    <meta
      property="og:description"
      content="Informace o parkování na Studentském Velehradě 2026 v obci Velehrad."
    />
    <meta
      property="og:image"
      content="https://studentskyvelehrad.cz/images/cover.webp"
    />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content="https://studentskyvelehrad.cz/informace"
    />
    <meta
      property="twitter:title"
      content="Parkování - Studentský Velehrad 2026"
    />
    <meta
      property="twitter:description"
      content="Informace o parkování při Studentském Velehradě 2026 v obci Velehrad."
    />
    <meta
      property="twitter:image"
      content="https://studentskyvelehrad.cz/images/cover.webp"
    />

    <link
      rel="preload"
      href="/fonts/Ohrada.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/HelveticaNow.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/HelveticaNowBold.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Italic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/OpenSans-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" as="image" href="/images/cover.webp" />
    <link rel="preload" as="image" href="/images/SV26_FB.svg" />
    <link rel="preload" as="image" href="/images/SV26_IG.svg" />
    <link rel="preload" as="image" href="/images/SV26_YT.svg" />
    <link rel="preload" as="image" href="/images/arrow-up-circle.svg" />
    <link rel="preload" as="image" href="/images/logo_b_transparent.webp" />
    <link rel="preload" as="image" href="/images/parking.jpeg" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        position: relative;
        z-index: 10;
        width: 100%;
        padding: 70px 0 40px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 1200px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        color: #424753;
        text-align: center;
        width: 100%;
        z-index: 999;
      }

      .parking-wrap {
        max-width: 1150px;
        margin: 0 auto;
        padding: 0 15px;
      }

      .parking-title {
        margin-bottom: 1rem;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
      }

      .about p {
        margin-bottom: 1.5rem;
        line-height: 2;
      }

      .parking-map {
        display: block;
        margin: 0 auto 1.5rem auto;
        max-width: 100%;
        width: 100%;
        border-radius: 20px;
        height: auto;
        box-shadow: 0 14px 40px rgba(26, 39, 100, 0.12);
      }

      .parking-notes {
        max-width: 900px;
        margin: 0 auto;
        text-align: left;
      }

      .parking-notes ul {
        margin: 0;
        padding-left: 1.2rem;
      }

      @media (max-width: 640px) {
        .about-text {
          width: auto;
        }

        .about {
          padding-top: 40px;
        }

        .about-flex {
          flex-direction: column;
          gap: 1rem;
          margin: 1rem auto;
        }

        .parking-notes {
          text-align: left;
        }

        .about p {
          line-height: 1.8;
        }
      }
    </style>
  </head>

  <body>
    <Navigation />
    <MobileMenu />

    <div class="content">
      <div class="nav-bar"></div>
      <div class="cover-bar"></div>
      <section class="about">
        <div class="parking-wrap">
          <div class="about-text parking-title">
            <h2>Parkování v obci Velehrad</h2>
            <p>
              Pro návštěvníky je k dispozici několik parkovacích míst v obci i
              v bezprostředním okolí areálu. Nejvhodnější místa jsou vyznačena
              na mapě níže.
            </p>
          </div>

          <img
            class="parking-map"
            src="/images/parking.png"
            alt="Mapa parkování v obci Velehrad"
          />

          <div class="about-text parking-notes">
            <p>
              Prosíme, parkuj hlavně podél ulice Hradišťská na označených místech a dbej
              pokynů organizátorů.
            </p>
          </div>
        </div>

        <Footer />
      </section>
    </div>
    <button id="scrollTopBtn" aria-label="Zpět nahoru"></button>
    <div class="bottom-bar"></div>

    <script type="module" src="/script_v3.js" defer></script>
  </body>
</html>
