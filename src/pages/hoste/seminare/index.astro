---
import Navigation from "../../../components/Navigation.astro";
import MobileMenu from "../../../components/MobileMenu.astro";
import Footer from "../../../components/Footer.astro";
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Workshopy</title>
    <meta name="description" content="Workshopy Studentského Velehradu 2026" />

    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        position: relative;
        z-index: 10;
        width: 100%;
        padding-top: 70px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 980px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        width: 100%;
        color: #424753;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
        letter-spacing: 1.4px;
      }

      .about p {
        margin-bottom: 1rem;
        line-height: 2;
      }

      .placeholder {
        border: 2px dashed #d9d9d9;
        padding: 1.2rem;
        color: #6a6f7a;
      }
    </style>
  </head>

  <body>
    <Navigation />
    <MobileMenu />

    <div class="content">
      <div class="nav-bar"></div>
      <div class="cover-bar"></div>

      <section class="about">
        <div class="about-flex">
          <div class="about-text">
            <h2>Workshopy</h2>
            <p>Program workshopů bude zveřejněn již brzy.</p>
          </div>
        </div>

        <Footer />
      </section>
    </div>
  </body>
</html>
