---
import Navigation from "../../../components/Navigation.astro";
import MobileMenu from "../../../components/MobileMenu.astro";
import Footer from "../../../components/Footer.astro";

const organizations = [
  {
    name: "Díky, že můžem",
    file: "Díky, že můžem (Skrytá církev).webp",
    imageClass: "image-contain",
    description:
      "Díky, že můžem je nevládní organizace složená z studentů a mladých lidí, kterým není lhostejný okolní svět. Chceme společnost spojovat, vzdělávat a podněcovat v ní chuť aktivně se na naší budoucnosti podílet. Postupně se z nás stala organizace, která nejen slaví svobodu v centru Prahy, ale stojí za spoustou celoročních projektů, které sahají do všech regionů v naší zemi. Druhý den letošního Studentského Velehradu uvedou audiodokumentární instalaci Skrytá církev a debatu Spací mladí svět?.",
    url: "https://dikyzemuzem.cz/",
    anchor: "diky-ze-muzem"
  },
  {
    name: "Někdo ti uvěří",
    file: null,
    description:
      "Spolek Někdo Ti uvěří pracuje s tématem zneužívání v církvích. Doprovázíme oběti, vzděláváme, snažíme se měnit prostředí v církvích tak, aby bylo citlivé k traumatu. Stalo se vám něco, o čem potřebujete mluvit? Kamarádka se vám svěřila se zneužitím a nejste si jistí, jak ji nejlépe podpořit? Zažili nebo viděli jste něco divného? V rodině, ve farnosti nebo jinde došlo ke zneužití a je těžké se v tom vyznat? Kněz nebo učitel se k vám nebo k někomu dalšímu choval jinak, než od člověka v jeho roli čekáte? Nemusíte být sami, jsme k dispozici. V sobotu 2.5. v čase 11:30-16:00 spolek nabízí konzultace všem účastníkům SV. Najdete nás v budově Stojanova gymnázia v blízkosti hlavní registrace nebo nám zavolejte na tel. 608 417 404. Ke konzultaci vám bude k dispozici Marek Drábek, který pracuje jako terapeut, doprovází oběti zneužívání a lektoruje preventivní programy. Je katolický kněz, člen řádu premonstrátů. Anna Ptáčková je výkonnou ředitelkou spolku Někdo Ti uvěří, má na starosti první komunikaci s lidmi, kteří se na spolek obrátí, pracuje jako terapeutka. Je vdaná, má 3 děti.",
    url: "https://www.nekdotiuveri.cz/",
    anchor: "nekdo-ti-uveri"
  },
  {
    name: "Institut Pallium",
    file: null,
    description:
      "Měníme systém péče o vážně nemocné děti a jejich rodiny. Propojujeme a podporujeme všechny, kteří se podílejí na péči o děti a dospívající se závažným život limitujícím či ohrožujícím onemocněním. Vzděláváme profesionály v dětské paliativní péči, navrhujeme a pilotujeme nové služby s cílem zlepšit kvalitu a dostupnost péče. Na letošním Studentském Velehradě nám své zkušenosti předá ředitel institutu Pallium Jiří krejčí (páteční přednáška Dětská paliativní péče jako životní cesta) a projektový manažer Petr Wiselka (páteční workshop Paliativní péče a já).",
    url: "https://pallium.cz/",
    anchor: "pallium"
  },
  {
    name: "Františkova ekonomika",
    file: "Frantiskova ekonomika.webp",
    description:
      "Jsme křesťanské společenství mladých, které otevírá otázky víry, života a odpovědnosti v dnešním světě. Společně se snažíme žít evangelium. Ukazujeme, že spiritualita a životní styl patří k sobě. Věříme, že spravedlnost, péče o druhé, vztahy, společnost i přírodu nejsou okrajová témata, ale samotná podstata křesťanské spirituality. Zástupci k Františkovy ekonomiky povedou v pátek workshop Být nadějí pro svět.",
    url: "https://www.frantiskovaekonomika.org/",
    anchor: "frantiskova-ekonomika"
  },
  {
    name: "Hledám Boha",
    file: "Hledam Boha_Marek Chvatal.webp",
    description:
      "HledamBoha.cz, je nezávislá křesťanská nezisková organizace. Vytváří prostor pro hledání odpovědí na otázky života a víry. Propojujeme skrze webovou platformu, e-mailovou komunikaci, sociální sítě a online kurzy zájemce s proškolenými průvodci, kteří je provázejí na jejich cestě duchovního hledání. Spolupracujeme s křesťanskými organizacemi pod záštitou Ekumenické rady církví. Jako zástupce spolku se letošního ročníku Studentského Velehradu zúčastní ředitel projektu HledamBoha.cz Marek Chvátal, který v pátek a sobotu povede workshop Naslouchání aneb Sdílení evangelia, které baví obě strany.",
    url: "https://hledamboha.cz",
    anchor: "hledam-boha"
  },
  {
    name: "Logos ČR",
    file: "Logos.webp",
    description:
      "Logos vytváří bezpečný a otevřený prostor pro LGBTQ+ věřící, jejich příbuzné a přátele. Naše činnost se soustředí na duchovní doprovázení a tvorbu společenství, kde lze najít přijetí, pochopení i prostor pro vedení dialogu. Vedle toho se snažíme komunikovat s církvemi a zvyšovat povědomí o životě queer lidí. Již více než 30 let obohacujeme církev o naši menšinovou zkušenost a snažíme se ukazovat, že být gay, lesba či trans a zároveň věřící díky Bohu jde. Jako zástupce organizace se letošního ročníku Studentského Velehradu zúčastní současný předseda spolku Jiří Votava, který povede sobotní seminář Společenství Logos a cesta k inkluzivní církvi.",
    url: "https://www.logoscr.cz/",
    anchor: "logos-cr"
  },
  {
    name: "Antiochia",
    file: null,
    description:
      "Antiochia je katolické společenství mladých lidí, kteří chtějí přinášet evangelium lidem v každodenním životě. Každé léto vyrážejí jeho členové na evangelizační misie do různých míst v Česku, kde se setkávají s lidmi a sdílejí s nimi svou víru. Na letošním ročníku Studentského Velehradu vystoupí několik členů tohoto společenství a na sobotním semináři Jak v dnešní době svědčit o Bohu se podělí o své zkušenosti a svá osobní svědectví.",
    url: "https://antiochia.cz/",
    anchor: "antiochia"
  },
  {
    name: "NePornu",
    file: null,
    description:
      "V NePornu vytváříme bezpečný prostor, abychom podpořili naše klienty na cestě ke změně a rozvoji. Proto rozšiřujeme povědomí o problematice pornografie a pomáháme lidem, kteří zápasí se závislostí na pornografii, včetně jejich partnerů, rodičů a dalších jedinců v jejich okolí. Naším hlavním heslem je: Nebuď na to sám! Seminář Odvrácená strana pornografie povede v sobotu zakladatel spolku NePornu Pete Lupton.",
    url: "https://nepornu.cz/",
    anchor: "neporno"
  },
  {
    name: "Sadba",
    file: null,
    description:
      "Salesiánská asociace Dona Boska, z. s. (zkráceně SADBA) je nezisková organizace, která zprostředkovává salesiánské misijní dobrovolnictví skrze program Adopce nablízko, organizuje pobytové akce, poskytuje rozvojovou pomoc, osvětu a vzdělávání. Posláním Sadby je pečovat o děti a mladé lidi ve světě, v duchu salesiánských hodnot zvláště o ty znevýhodněné, a propojovat světy skrze dobrovolnictví, vzdělávání a solidaritu. Sobotním workshopem Rok v Albánii vás provede Marie Kašparová.",
    url: "https://www.sadba.org/",
    anchor: "sadba"
  },
  {
    name: "Mary´s Meals",
    file: null,
    description:
      "Mary’s Meals je mezinárodní charitativní organizace zabezpečující dětem v nejchudších zemích světa (kde hlad a chudoba brání dětem ve vzdělávání) jedno jídlo denně ve škole. Jídlo přivádí děti do škol a vzdělání jim dává naději vymanit se z bludného kruhu chudoby. Páteční workshop Creativ Impact Lab: Jak využít talent pro Mary’s Meals povede Kristína Třešková spolu se svými koleky z Mary´s Meals.",
    url: "https://www.marysmeals.cz/",
    anchor: "marysmeals"
  },
  {
    name: "Kurzy Alfa",
    file: null,
    description:
      "Kurzy Alfa nabízejí příležitost prozkoumat křesťanskou víru a diskutovat o zásadních životních otázkách. Je to místo, kde je každý vítán, každý se může na cokoliv zeptat a říct svůj názor. Alfa probíhá po celém světě v kavárnách, církvích, univerzitách, obývacích pokojích, ale třeba i ve vězení. Každá Alfa má společné tři věci: jídlo, promluvu a diskusi o tématu. To vše budete moci zakusit na nedělním workshopu Jak přicházet s evangeliem vhod.",
    url: null,
    anchor: "kurzy-alfa"
  }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Organizace</title>
    <meta name="description" content="Organizace Studentského Velehradu 2026" />

    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        position: relative;
        z-index: 10;
        width: 100%;
        padding-top: 70px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 1200px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        width: 100%;
        color: #424753;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
        letter-spacing: 1.4px;
      }

      .about p {
        margin: 0 auto 1.5rem auto;
        line-height: 2;
        max-width: 950px;
        text-align: center;
      }

      .organization-grid {
        width: 100%;
        max-width: 1200px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.1rem;
        margin: 0 auto;
      }

      .organization-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        padding: 1rem;
        text-align: center;
      }

      .organization-card img {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto;
        display: block;
      }

      .organization-card img.image-contain {
        object-fit: contain;
        background: #fff;
        padding: 12px;
      }

      .organization-card .image-fallback {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        margin: 0 auto;
        position: relative;
        background: #f3f4f7;
        overflow: hidden;
      }

      .organization-card .image-fallback::before {
        content: "";
        position: absolute;
        top: 34px;
        left: 50%;
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: #b9bec8;
        transform: translateX(-50%);
      }

      .organization-card .image-fallback::after {
        content: "";
        position: absolute;
        left: 50%;
        bottom: 28px;
        width: 92px;
        height: 52px;
        border-radius: 52px 52px 18px 18px;
        background: #b9bec8;
        transform: translateX(-50%);
      }

      .organization-card h3 {
        margin: 0.9rem 0 0.4rem;
        font-size: 16px;
        color: #1a2764;
        text-align: center;
      }

      .organization-card h3 a {
        color: inherit;
        text-decoration: none;
      }

      .organization-card h3 a:hover,
      .organization-card h3 a:focus-visible {
        text-decoration: underline;
      }

      .organization-card p {
        margin: 0 auto 0 auto;
        color: #5b5f68;
        line-height: 1.6;
        text-align: center;
        max-width: 950px;
      }

      .organization-card p a {
        color: #1a5490;
        text-decoration: none;
        border-bottom: 1px solid #1a5490;
      }

      .organization-card p a:hover,
      .organization-card p a:focus-visible {
        text-decoration: underline;
      }

      .external-link {
        display: inline-flex;
        align-items: center;
        gap: 0.2em;
      }
      .external-link-icon svg {
        color: #1a5490;
        opacity: 0.7;
        transition: opacity 0.2s;
      }
      .external-link:hover .external-link-icon svg,
      .external-link:focus-visible .external-link-icon svg {
        opacity: 1;
        color: var(--color-accent, #eeaf13);
      }
      @media (max-width: 980px) {
        .about-flex {
          flex-direction: column;
          gap: 1rem;
        }

        .organization-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <Navigation />
    <MobileMenu />

    <div class="content">
      <div class="nav-bar"></div>
      <div class="cover-bar"></div>

      <section class="about">
        <div class="about-flex">
          <div class="about-text">
            <h2>Organizace</h2>
          </div>
        </div>

        <div class="about-flex">
          <div class="organization-grid">
            {
              organizations.map((org) => (
                <article class="organization-card" id={org.anchor}>
                  {
                    org.file ? (
                      <img
                        src={`/images/hoste/organizace/${encodeURIComponent(org.file)}`}
                        alt={org.name}
                        class={org.imageClass}
                        loading="lazy"
                      />
                    ) : (
                      <div class="image-fallback" aria-hidden="true"></div>
                    )
                  }
                  <h3>
                    {org.url ? (
                      <a href={org.url} target="_blank" rel="noopener noreferrer" class="external-link">
                        {org.name}
                        <span class="external-link-icon" aria-hidden="true" style="margin-left:0.35em;display:inline-block;vertical-align:middle;">
                          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;">
                            <g>
                              <path d="M14.5 3.5H17.5V6.5"/>
                              <path d="M10 10L17.5 2.5"/>
                              <rect x="3.5" y="3.5" width="13" height="13" rx="2"/>
                            </g>
                          </svg>
                        </span>
                      </a>
                    ) : (
                      org.name
                    )}
                  </h3>
                  <p set:html={org.description}></p>
                </article>
              ))
            }
          </div>
        </div>

        <Footer />
      </section>
    </div>
    <script type="module" src="/script_v3.js" defer></script>
  </body>
</html>
