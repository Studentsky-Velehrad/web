---
import Navigation from "../../components/Navigation.astro";
import MobileMenu from "../../components/MobileMenu.astro";
import Footer from "../../components/Footer.astro";
---

<!doctype html>
<html lang="cs">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Hosté</title>
		<meta name="description" content="Hosté Studentského Velehradu 2026" />

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/favicon/apple-touch-icon.png"
		/>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://studentskyvelehrad.cz/hoste" />
		<meta property="og:title" content="Hosté" />
		<meta
			property="og:description"
			content="Hosté Studentského Velehradu 2026"
		/>
		<meta
			property="og:image"
			content="https://studentskyvelehrad.cz/images/cover.webp"
		/>

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://studentskyvelehrad.cz/hoste" />
		<meta property="twitter:title" content="Hosté" />
		<meta
			property="twitter:description"
			content="Hosté Studentského Velehradu 2026"
		/>
		<meta
			property="twitter:image"
			content="https://studentskyvelehrad.cz/images/cover.webp"
		/>

		<link
			rel="preload"
			href="/fonts/Ohrada.otf"
			as="font"
			type="font/otf"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/HelveticaNow.otf"
			as="font"
			type="font/otf"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/HelveticaNowBold.otf"
			as="font"
			type="font/otf"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/OpenSans-Regular.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/OpenSans-Italic.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/OpenSans-Bold.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link rel="preload" as="image" href="/images/cover.webp" />
		<link rel="preload" as="image" href="/images/SV26_FB.svg" />
		<link rel="preload" as="image" href="/images/SV26_IG.svg" />
		<link rel="preload" as="image" href="/images/SV26_YT.svg" />
		<link rel="preload" as="image" href="/images/arrow-up-circle.svg" />
		<link rel="preload" as="image" href="/images/logo_b_transparent.webp" />
		<link rel="stylesheet" href="/styles_v1.css" />

		<style>
			.about {
				position: relative;
				z-index: 10;
				width: 100%;
				padding-top: 70px;
				overflow: hidden;
			}

			.about-flex {
				display: flex;
				justify-content: center;
				text-align: center;
				max-width: 1200px;
				margin: 2rem auto;
				gap: 20px;
				padding: 0 15px;
			}

			.about-text {
				color: #424753;
				text-align: center;
				width: 100%;
				position: relative;
				z-index: 1;
			}

			.about h2 {
				text-transform: uppercase;
				margin-bottom: 1.5rem;
				line-height: 1.4;
				font-size: 18px;
			}

			.about p {
				margin: 0 auto 1.5rem auto;
				line-height: 2;
				max-width: 900px;
				text-align: center;
			}

			.about p.spacing {
				letter-spacing: 1.4px;
			}

			.about p.intro {
				font-size: 17px;
				padding: 0;
			}

			.signpost-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(220px, 320px));
				gap: 16px;
				justify-content: center;
				width: 100%;
				position: relative;
				z-index: 1;
			}

			.signpost-link {
				display: grid;
				grid-template-columns: 1fr auto;
				align-items: center;
				gap: 0.7rem;
				background: linear-gradient(140deg, #ffffff, #fff8e8);
				border: 2px solid #f0c457;
				color: #12225d;
				text-decoration: none;
				text-transform: uppercase;
				letter-spacing: 1.2px;
				padding: 1rem 1.1rem;
				transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
				box-shadow: 0 10px 20px rgba(15, 27, 72, 0.08);
				font-size: 15px;
			}

			.signpost-link:hover,
			.signpost-link:focus-visible {
				transform: translateY(-3px);
				box-shadow: 0 16px 28px rgba(15, 27, 72, 0.16);
				border-color: #eeaf13;
			}

			.signpost-title {
				font-weight: 700;
				text-align: left;
			}

			.signpost-arrow {
				font-size: 22px;
				line-height: 1;
				color: #eeaf13;
				transition: transform 0.2s ease;
			}

			.signpost-link:hover .signpost-arrow,
			.signpost-link:focus-visible .signpost-arrow {
				transform: translateX(3px);
			}

			@media (max-width: 640px) {
				.about-flex {
					flex-direction: column;
					gap: 1rem;
				}

				.about-text {
					width: auto;
				}

				.signpost-grid {
					grid-template-columns: 1fr;
				}

				.about p.intro {
					font-size: 16px;
					padding: 0;
				}
			}
		</style>
	</head>

	<body>
		<Navigation />
		<MobileMenu />

		<div class="content">
			<div class="nav-bar"></div>
			<div class="cover-bar"></div>

			<section class="about">
				<div class="about-flex">
					<div class="about-text">
						<h2 class="spacing">Hosté</h2>
						<p class="intro">
							V letošním roce přijali naše laskavé pozvání hosté z celé republiky, známí i neznámí. 
							Obohatí nás zástupci akademické obce i odborníci z praxe. 
							Někteří s námi budou sdílet své pracovní zkušenosti, jiní své osobní příběhy. 
							Všichni se rozhodli věnovat nám svůj čas, za což jim patří srdečný dík.
						</p>
					</div>
				</div>

				<div class="about-flex">
					<div class="signpost-grid">
						<a class="signpost-link" href="/hoste/prednasky">
							<span class="signpost-title">Přednášky</span>
							<span class="signpost-arrow" aria-hidden="true">&#8250;</span>
						</a>
						<a class="signpost-link" href="/hoste/organizace">
							<span class="signpost-title">Organizace</span>
							<span class="signpost-arrow" aria-hidden="true">&#8250;</span>
						</a>
						<a class="signpost-link" href="/hoste/liturgie">
							<span class="signpost-title">Liturgie</span>
							<span class="signpost-arrow" aria-hidden="true">&#8250;</span>
						</a>
						<a class="signpost-link" href="/hoste/koncerty">
							<span class="signpost-title">Koncerty</span>
							<span class="signpost-arrow" aria-hidden="true">&#8250;</span>
						</a>
					</div>
				</div>

				<Footer />
			</section>
		</div>
	</body>
</html>
