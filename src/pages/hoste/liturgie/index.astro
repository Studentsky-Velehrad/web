---
import Navigation from "../../../components/Navigation.astro";
import MobileMenu from "../../../components/MobileMenu.astro";
import Footer from "../../../components/Footer.astro";

const liturgyGuests = [
  {
    name: "Mons. Stanislav Přibyl",
    file: "Stanislav Přibyl 1.webp",
    anchor: "pribyl",
    description:
      "Nově jmenovaný pražský arcibiskup se narodil do pražské hudební rodiny. Po maturitě vstoupil do řádu redemptoristů a r. 1996 byl vysvěcen na kněze. Působil na poutním místě Svatá Hora u Příbrami, byl prezidentem Arcidiecézní charity Praha, generálním vikářem diecéze litoměřické a generálním sekretářem České biskupské konference. V roce 2024 byl vysvěcen na litoměřického biskupa a nyní v únoru 2026 se stal nejmladším pražským arcibiskupem za více než sto let. Otec arcibiskup nás navštíví v neděli. Krom setkání na mši svaté máte možnost potkat se s ním na semináři S otcem biskupem na jedné lodi."
  },
  {
    name: "Mons. Josef Nuzík",
    file: "Josef Nuzík 1.webp",
    anchor: "nuzik",
    description:
      "Pochází z početné rodiny z jihomoravského Strání. Nejprve pracoval jako soustružník, ale po několika letech začal studovat na Římskokatolické cyrilometodějské bohoslovecké fakultě v Praze a r. 1995 byl v Olomouci vysvěcen na kněze. V únoru 2024 byl papežem Františkem jmenován 15. olomouckým arcibiskupem. Jeho biskupským heslem je Hlásat radostnou zvěst. Otec arcibiskup nás navštíví v pátek. Krom setkání na mši svaté máte možnost potkat se s ním na semináři S otcem biskupem na jedné lodi."
  },
  {
    name: "Mons. Prokop Brož",
    file: "Prokop Brož 1.webp",
    anchor: "broz",
    description:
      "Vyrůstal s 6 sourozenci v Červeném Kostelci, v roce 1997 byl vysvěcen na kněze. Působil např. v Nové Pace a v Kutné Hoře, studoval na Papežské lateránské univerzitě a na Papežské univerzitě Gregoriana. Od roku 2024 je pomocným biskupem královéhradecké diecéze a titulárním biskupem litomyšlským. Jeho biskupské heslo je Stačí ti moje milost."
  },
  {
    name: "P. Miroslav Herold",
    file: "Miroslav Herold 1.webp",
    anchor: "herold",
    description:
      "Narodil se v Praze a po maturitě na Arcibiskupském gymnáziu vstoupil do Tovaryšstva Ježíšova. Studoval např. na Cyrilometodějské teologické fakultě a na Papežské gregoriánské univerzitě. V roce 2006 byl v kostele sv. Ignáce v Praze vysvěcen na kněze a působil jako kaplan akademické farnosti při kostele Panny Marie Sněžné v Olomouci. Poté zastával funkci studentského kaplana při VKH Brno a od ledna 2026 patří do pražské komunity jezuitů."
  },
  {
    name: "P. Tomáš Čirž",
    file: "Tomáš Čirž 1.webp",
    anchor: "cirz",
    description:
      "Tomáš Čirž je učitelem a školním kaplanem na Biskupském gymnáziu v Ostravě, kde učí náboženství a matematiku. Zároveň je kaplanem pro vysokoškoláky ve VKH Ostrava. Pochází z Hněvošic. Kněžské svěcení přijal v roce 2008. Základní kurz teologie studoval v Olomouci, doktorské studium teologie absolvoval na Vídeňské univerzitě. Mezi jeho zájmy patří mimo jiné i výklad příběhů knihy Genesis. Na letošním Studentském Velehradě nám na toto téma nabídne přednášku, která se bude konat v nedělním přednáškovém bloku."
  }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Liturgie</title>
    <meta name="description" content="Liturgie Studentského Velehradu 2026" />

    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        position: relative;
        z-index: 10;
        width: 100%;
        padding-top: 70px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 1200px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        width: 100%;
        color: #424753;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
        letter-spacing: 1.4px;
      }

      .about p {
        margin: 0 auto 1.5rem auto;
        line-height: 2;
        max-width: 950px;
        text-align: center;
      }

      .liturgy-grid {
        width: 100%;
        max-width: 1200px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.1rem;
      }

      .liturgy-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        padding: 1rem;
        text-align: center;
      }

      .liturgy-card img {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        object-fit: cover;
      }

      .liturgy-card h3 {
        margin: 0.9rem 0 0.4rem;
        font-size: 16px;
        color: #1a2764;
        text-align: center;
      }

      .liturgy-card h3 a {
        color: inherit;
        text-decoration: none;
      }

      .liturgy-card h3 a:hover,
      .liturgy-card h3 a:focus-visible {
        text-decoration: underline;
      }

      .liturgy-card p {
        margin: 0 auto;
        color: #5b5f68;
        line-height: 1.6;
        text-align: center;
        max-width: 950px;
      }

      @media (max-width: 980px) {
        .about-flex {
          flex-direction: column;
          gap: 1rem;
        }

        .liturgy-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <Navigation />
    <MobileMenu />

    <div class="content">
      <div class="nav-bar"></div>
      <div class="cover-bar"></div>

      <section class="about">
        <div class="about-flex">
          <div class="about-text">
            <h2>Liturgie</h2>
          </div>
        </div>

        <div class="about-flex">
          <div class="liturgy-grid">
            {
              liturgyGuests.map((guest) => (
                <article class="liturgy-card" id={guest.anchor}>
                  <img
                    src={`/images/hoste/liturgie/${encodeURIComponent(guest.file)}`}
                    alt={guest.name}
                    loading="lazy"
                  />
                  <h3><a href={`#${guest.anchor}`}>{guest.name}</a></h3>
                  <p>{guest.description}</p>
                </article>
              ))
            }
          </div>
        </div>

        <Footer />
      </section>
    </div>
    <script type="module" src="/script_v3.js" defer></script>
  </body>
</html>
