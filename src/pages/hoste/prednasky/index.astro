---
import Navigation from "../../../components/Navigation.astro";
import MobileMenu from "../../../components/MobileMenu.astro";
import Footer from "../../../components/Footer.astro";

const speakers = [
  { name: "Alexandr Flek", file: "Alexandr Flek 1.webp", anchor: "flek" },
  { name: "Daniel Tůma", file: "Daniel Tůma 1.webp", anchor: "tuma" },
  { name: "David Krajíček", file: "David Krajíček 1.webp", anchor: "krajicek" },
  { name: "František Talíř", file: "František Talíř 1.webp", anchor: "talir" },
  { name: "Jan Regner", file: "Jan Regner 1.webp", anchor: "regner" },
  { name: "Jana Matoušková", file: "Jana Matoušková 1.webp", anchor: "matouskova" },
  { name: "Jiří Krejčí", file: "Jiří Krejčí 1.webp", anchor: "krejci" },
  { name: "Josef Prokeš", file: "Josef Prokeš 1.webp", anchor: "prokes" },
  { name: "Kika Štamberová", file: "Kika Štamberová 1.webp", anchor: "stamberova" },
  { name: "Marek Chvátal", file: "Marek Chvátal 1.webp", anchor: "chvatal" },
  { name: "Marek Drábek", file: "Marek Drábek 1.webp", anchor: "drabek" },
  { name: "Markéta a Milan Jiroutovi", file: "Markéta a Milan Jiroutovi 1.webp", anchor: "jiroutovi" },
  { name: "Pater Pepa", file: "Pater Pepa 1.webp", anchor: "pepa" },
  { name: "Petr Wiselka", file: "Petr Wiselka 1.webp", anchor: "wiselka" },
  { name: "Simona Cupová", file: "Simona Cupova 1.webp", anchor: "cupova" },
  { name: "Tomáš Halik", file: "Tomáš Halík 1.webp", anchor: "halik" },
  { name: "Václav Uher", file: "Václav Uher 1.webp", anchor: "uher" }
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Přednášející</title>
    <meta name="description" content="Přednášející Studentského Velehradu 2026" />

    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="stylesheet" href="/styles_v1.css" />

    <style>
      .about {
        width: 100%;
        padding-top: 70px;
      }

      .about-flex {
        display: flex;
        justify-content: center;
        text-align: center;
        max-width: 1200px;
        margin: 2rem auto;
        gap: 20px;
        padding: 0 15px;
      }

      .about-text {
        width: 100%;
        color: #424753;
      }

      .about h2 {
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        line-height: 1.4;
        font-size: 18px;
        letter-spacing: 1.4px;
      }

      .about p {
        margin: 0 auto 1.5rem auto;
        line-height: 2;
        max-width: 950px;
      }

      .speaker-grid {
        width: 100%;
        max-width: 1200px;
        display: grid;
        grid-template-columns: repeat(4, minmax(200px, 1fr));
        gap: 1.1rem;
      }

      .speaker-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        padding: 1rem;
        text-align: center;
      }

      .speaker-card img {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        object-fit: cover;
      }

      .speaker-card h3 {
        margin: 0.9rem 0 0.4rem;
        font-size: 16px;
        color: #1a2764;
      }

      .speaker-card h3 a {
        color: inherit;
        text-decoration: none;
      }

      .speaker-card h3 a:hover,
      .speaker-card h3 a:focus-visible {
        text-decoration: underline;
      }

      .speaker-card p {
        margin: 0;
        color: #5b5f68;
        line-height: 1.6;
      }

      @media (max-width: 980px) {
        .speaker-grid {
          grid-template-columns: repeat(2, minmax(180px, 1fr));
        }
      }

      @media (max-width: 640px) {
        .about-flex {
          flex-direction: column;
          gap: 1rem;
        }

        .speaker-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body>
    <Navigation />
    <MobileMenu />

    <div class="content">
      <div class="nav-bar"></div>
      <div class="cover-bar"></div>

      <section class="about">
        <div class="about-flex">
          <div class="about-text">
            <h2>Přednášející</h2>
            <p>
              Naši hosté s námi budou sdílet své zkušenosti, vědomosti, zážitky i názory.
              Podrobné anotace budou doplněny.
            </p>
          </div>
        </div>

        <div class="about-flex">
          <div class="speaker-grid">
            {
              speakers.map((speaker) => (
                <article class="speaker-card" id={speaker.anchor}>
                  <img
                    src={`/images/hoste/prednasky/${encodeURIComponent(speaker.file)}`}
                    alt={speaker.name}
                    loading="lazy"
                  />
                  <h3><a href={`#${speaker.anchor}`}>{speaker.name}</a></h3>
                  <p>Lorem ipsum dolor sit amet.</p>
                </article>
              ))
            }
          </div>
        </div>

        <Footer />
      </section>
    </div>
  </body>
</html>
